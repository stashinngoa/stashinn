# ==============================================================================
# StashInn Portal — Environment Variables Template
# ==============================================================================
# Copy this file to `.env.local` and fill in the values for local development.
# NEVER commit `.env.local` or any file containing real secrets to Git.
#
# For detailed per-environment documentation, see: docs/ENVIRONMENT.md
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase — Database & Auth
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ------------------------------------------------------------------------------

# Public Supabase project URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anonymous key (safe to expose to client — used with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# Service role key (SERVER-SIDE ONLY — bypasses RLS, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ------------------------------------------------------------------------------
# Razorpay — Payment Gateway
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# ------------------------------------------------------------------------------

# Razorpay key ID (safe to expose to client for checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Razorpay key secret (SERVER-SIDE ONLY — used for order creation & verification)
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Razorpay webhook secret (SERVER-SIDE ONLY — used to verify webhook signatures)
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------

# App environment identifier
NEXT_PUBLIC_APP_ENV=development

# Base URLs for each app (used for cross-app links and redirects)
NEXT_PUBLIC_CUSTOMER_URL=http://localhost:3000
NEXT_PUBLIC_PARTNER_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# ------------------------------------------------------------------------------
# External Services (Stage 5+)
# ------------------------------------------------------------------------------

# SendGrid / Resend — Email delivery
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Twilio / Meta — WhatsApp / SMS
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google OAuth (for Social Login — Stage 8)
# GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# Sentry — Error Tracking (Stage 7)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# Google Sheets Export (Stage 8)
# GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
